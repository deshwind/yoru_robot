# Shared ROS 2 network settings - source this on BOTH machines
# (start_server.sh and start_pi_minimal.sh do it automatically).

export ROS_DOMAIN_ID=42
export RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Unicast peer discovery — fixes one-way multicast on Wi-Fi routers that
# block or asymmetrically forward multicast.  Both machines explicitly
# contact each other by IP so DDS discovery works in both directions.
# Update fastdds_unicast.xml if your router reassigns either IP.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export FASTRTPS_DEFAULT_PROFILES_FILE="${SCRIPT_DIR}/fastdds_unicast.xml"
