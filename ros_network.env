# Shared ROS 2 network settings — source this on BOTH Pi and laptop.
# start_server.sh and start_pi_minimal.sh do this automatically.

export ROS_DOMAIN_ID=42
export RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Discovery server — the laptop acts as the central discovery broker.
# This replaces multicast (which Wi-Fi routers often block one-way) with
# a reliable unicast discovery channel.
#
# The laptop's IP is resolved from its mDNS hostname so the link keeps
# working even when the router hands out a new DHCP address (e.g. after a
# reboot or moving between networks). If mDNS resolution fails, the
# LAPTOP_IP_FALLBACK below is used — update it to the laptop's current IP
# (on the laptop run: hostname -I | awk '{print $1}').
LAPTOP_HOST="desh-Nitro-AN515-58.local"
LAPTOP_IP_FALLBACK="192.168.1.28"
_laptop_ip="$(getent hosts "$LAPTOP_HOST" 2>/dev/null | awk '{print $1}' | head -1)"
export ROS_DISCOVERY_SERVER="${_laptop_ip:-$LAPTOP_IP_FALLBACK}:11811"
export ROS_SUPER_CLIENT=true
