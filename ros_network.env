# Shared ROS 2 network settings — source this on BOTH Pi and laptop.
# start_server.sh, start_pi.sh and start_pi_minimal.sh do this automatically.

export ROS_DOMAIN_ID=42
export RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Discovery server — the ROBOT (Pi) hosts the discovery broker and the laptop
# connects out to it. Hosting on the Pi is deliberate: the robot is always on
# when the system runs, its firewall is inactive, and laptop-side firewalls
# never block *outbound* UDP. (Hosting on the laptop broke discovery whenever
# its firewall/second network interface got in the way.)
#
# The Pi's IP is resolved from its mDNS hostname so nothing here needs editing
# when DHCP hands out new addresses. The host can be multi-homed, so every
# candidate IPv4 (avahi + getent + fallback) is tried and the first one that
# answers a 1-second ping wins. IPv4 is forced: an IPv6 result would be
# malformed in ROS_DISCOVERY_SERVER (needs brackets) and silently break all
# discovery.
DISCOVERY_HOST="desh-desktop.local"   # the Pi
DISCOVERY_IP_FALLBACK="192.168.1.43"
_ipv4_re='([0-9]{1,3}\.){3}[0-9]{1,3}'
_candidates="$( { avahi-resolve -4 -n "$DISCOVERY_HOST" 2>/dev/null;
                  getent ahostsv4 "$DISCOVERY_HOST" 2>/dev/null;
                  echo "$DISCOVERY_IP_FALLBACK"; } | grep -oE "$_ipv4_re" | awk '!seen[$0]++')"
_discovery_ip=""
for _c in $_candidates; do
    if ping -c1 -W1 "$_c" >/dev/null 2>&1; then _discovery_ip="$_c"; break; fi
done
[ -z "$_discovery_ip" ] && _discovery_ip="$(echo "$_candidates" | head -1)"
export ROS_DISCOVERY_SERVER="${_discovery_ip:-$DISCOVERY_IP_FALLBACK}:11811"
export ROS_SUPER_CLIENT=true
