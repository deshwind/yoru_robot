# Shared ROS 2 network settings - source this on BOTH machines
# (start_server.sh and start_pi.sh do it automatically).
#
# On a home Wi-Fi router nothing else is needed: both machines use the same
# domain ID and find each other automatically (DDS multicast discovery).

export ROS_DOMAIN_ID=42
export RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# --- University / corporate Wi-Fi (multicast blocked) ------------------
# Uncomment BOTH lines and set the server PC's IP. Then, on the server only,
# also run once per boot:  fastdds discovery -i 0 -p 11811
#
# export ROS_DISCOVERY_SERVER=<SERVER_PC_IP>:11811
# export ROS_SUPER_CLIENT=true
